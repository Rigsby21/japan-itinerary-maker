# Copy this file to .env and fill in real values. Never commit .env to Git.

# Database (Phase 0) - get a connection URL from Supabase or Neon
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# Auth (Phase 1) - required for NextAuth. Generate a secret: openssl rand -base64 32
AUTH_SECRET="your-secret-at-least-32-chars-long"

# Optional - add these in later phases:
# GOOGLE_MAPS_API_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
