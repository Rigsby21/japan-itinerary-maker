// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Phase 0: Core data model for Japan Itinerary Maker ---

enum Role {
  USER
  CREATOR
  ADMIN
}

/// Single-stop cities: one main stop per city; use day trips + POIs for detail. Legacy: multiple days (stops) in one city.
enum ItineraryCityKind {
  SINGLE_STOP
  LEGACY_MULTI_DAY
}

model User {
  id                String       @id @default(cuid())
  email             String       @unique
  passwordHash      String?      // optional if using Supabase Auth later
  displayName       String?
  role              Role         @default(USER)
  stripeCustomerId  String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  itineraries       Itinerary[]
}

model Itinerary {
  id             String               @id @default(cuid())
  title          String
  slug           String               @unique
  description    String?
  authorId       String
  author         User                 @relation(fields: [authorId], references: [id], onDelete: Cascade)
  isFeatured     Boolean              @default(false)
  isPublic       Boolean              @default(true)
  budgetCurrency String               @default("USD")
  /// When set, each stop’s `calendarDate` is kept in trip order: start, start+1 day, … Clearing it removes auto mode and clears all stop calendar dates.
  tripStartDate  DateTime?            @db.Date
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  cities         ItineraryCity[]
  stops          ItineraryStop[]
  markerTypes    MarkerType[]
  travelTips     ItineraryTravelTip[]
  budgetLines    ItineraryBudgetLine[]
}

/// A city / region visit; stops are calendar days (see ItineraryStop). Kind controls whether multiple days are allowed.
model ItineraryCity {
  id          String            @id @default(cuid())
  itineraryId String
  itinerary   Itinerary         @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  name        String
  sortOrder   Int               @default(0)
  kind        ItineraryCityKind @default(SINGLE_STOP)
  stops       ItineraryStop[]

  @@index([itineraryId])
}

// --- Day trips (multi-leg from a stop; public + admin) ---

model DayTrip {
  id               String        @id @default(cuid())
  stopId           String
  stop             ItineraryStop @relation(fields: [stopId], references: [id], onDelete: Cascade)
  orderIndex       Int      @default(0)
  title            String
  shortDescription String?
  description      String?  @db.Text
  durationText     String?
  costNote         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  destinations DayTripDestination[]
  photos       DayTripPhoto[]

  @@index([stopId])
}

model DayTripDestination {
  id         String  @id @default(cuid())
  dayTripId  String
  dayTrip    DayTrip @relation(fields: [dayTripId], references: [id], onDelete: Cascade)
  orderIndex Int     @default(0)
  placeName  String
  lat        Float
  lng        Float
  notes      String?

  @@index([dayTripId])
}

model DayTripPhoto {
  id          String   @id @default(cuid())
  dayTripId   String
  dayTrip     DayTrip  @relation(fields: [dayTripId], references: [id], onDelete: Cascade)
  orderIndex  Int      @default(0)
  url         String?
  storagePath String?
  caption     String?
  createdAt   DateTime @default(now())

  @@index([dayTripId])
}

model ItineraryTravelTip {
  id          String    @id @default(cuid())
  itineraryId String
  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  orderIndex  Int       @default(0)
  title       String
  body        String
  createdAt   DateTime  @default(now())

  @@index([itineraryId])
}

model ItineraryBudgetLine {
  id          String    @id @default(cuid())
  itineraryId String
  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  orderIndex  Int       @default(0)
  category    String
  amount      Decimal   @db.Decimal(12, 2)
  note        String?

  @@index([itineraryId])
}

model ItineraryStop {
  id             String        @id @default(cuid())
  itineraryId    String
  itinerary      Itinerary     @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  cityId         String
  city           ItineraryCity @relation(fields: [cityId], references: [id], onDelete: Cascade)
  /// 1-based day within this city (Day 1, Day 2, …).
  dayIndexInCity Int
  orderIndex     Int           @default(0)
  placeName      String
  /// Optional extra location hint (DB column `city`); distinct from {@link ItineraryCity}.
  stopAreaLabel  String?       @map("city")
  lat            Float?
  lng            Float?
  /// Optional calendar day for this row (e.g. “March 4”); not required. Stored as DATE (no time-of-day).
  calendarDate   DateTime?     @db.Date
  notes          String?
  createdAt      DateTime      @default(now())
  pois           Poi[]
  dayTrips       DayTrip[]

  @@unique([cityId, dayIndexInCity])
  @@index([itineraryId])
  @@index([cityId])
}

// --- Phase 3 prep: custom POI markers + types + photo gallery ---

model MarkerType {
  id          String    @id @default(cuid())
  itineraryId String
  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  name        String
  colorHex    String
  createdAt   DateTime  @default(now())

  pois        Poi[]

  @@unique([itineraryId, name])
}

model Poi {
  id           String       @id @default(cuid())
  stopId       String
  stop         ItineraryStop @relation(fields: [stopId], references: [id], onDelete: Cascade)
  markerTypeId String?
  markerType   MarkerType?  @relation(fields: [markerTypeId], references: [id], onDelete: SetNull)

  title        String
  description  String?
  lat          Float
  lng          Float
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  photos       PoiPhoto[]

  @@index([stopId])
  @@index([markerTypeId])
}

model PoiPhoto {
  id          String   @id @default(cuid())
  poiId       String
  poi         Poi      @relation(fields: [poiId], references: [id], onDelete: Cascade)
  orderIndex  Int      @default(0)

  // One of these will be set:
  url         String?  // external URL (or public URL)
  storagePath String?  // Supabase Storage path (preferred for uploads)

  caption     String?
  createdAt   DateTime @default(now())

  @@index([poiId])
}
