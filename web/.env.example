# Copy this file to .env and fill in real values. Never commit .env to Git.

# Database (Phase 0) - get a connection URL from Supabase or Neon
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# Auth (Phase 1) - required for NextAuth. Generate a secret: openssl rand -base64 32
AUTH_SECRET="your-secret-at-least-32-chars-long"

# Phase 3 — Google Maps (public read-only map on itinerary pages; browser needs the "NEXT_PUBLIC_" prefix)
# Create a key in Google Cloud Console, enable "Maps JavaScript API", restrict key to that API + your HTTP origins.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional — if POI photos use Supabase Storage (public bucket), set the object URL prefix, e.g.
# https://YOUR_PROJECT.supabase.co/storage/v1/object/public/YOUR_BUCKET
# (no trailing slash). Omitted: featured cards only show images with direct `url` on PoiPhoto.
# NEXT_PUBLIC_POI_PHOTO_STORAGE_BASE_URL=

# Optional - add these in later phases:
# GOOGLE_MAPS_API_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
